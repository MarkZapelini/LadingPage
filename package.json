{
  "name": "zcore",
  "version": "1.0.0",
  "private": true,
  "description": "Z-Core E-commerce Premium",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "node --watch backend/server.js",
    "install:backend": "npm install --prefix backend",
    "seed": "node backend/src/db/seed.js",
    "serve:ps": "powershell -ExecutionPolicy Bypass -File scripts/start-server-porta8080.ps1",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "vercel:login": "npx vercel login",
    "vercel:deploy": "npx vercel --prod"
  },
  "keywords": ["ecommerce", "zcore"],
  "author": "Z-Core Team",
  "license": "MIT"
}
