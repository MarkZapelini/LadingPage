<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <script>(function(){try{var t=localStorage.getItem('zcore-theme');document.documentElement.setAttribute('data-theme',t==='dark'?'dark':'light');}catch(e){}})();</script>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Redefinir Senha — Z-Core</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link rel="stylesheet" href="../css/style.css">
  <link rel="stylesheet" href="../css/responsive.css">
  <link rel="stylesheet" href="../css/pages/reset-password.css">
</head>
<body>

<div class="reset-theme-wrap">
  <button type="button" class="theme-toggle" aria-label="Ativar modo escuro" title="Modo escuro">
    <i class="fas fa-sun theme-icon-light" aria-hidden="true"></i>
    <i class="fas fa-moon theme-icon-dark" aria-hidden="true"></i>
  </button>
</div>

<div class="reset-container">
  <div class="reset-card" id="resetCard">
    <div class="reset-title"><i class="fas fa-key reset-title-icon"></i>Redefinir Senha</div>
    <div class="reset-desc">Digite sua nova senha abaixo</div>
    
    <div id="mensagem"></div>
    
    <div id="formRedefinir">
      <div class="form-group">
        <label>Nova Senha</label>
        <input type="password" id="novaSenha" placeholder="Mínimo 4 caracteres">
      </div>
      <div class="form-group">
        <label>Confirmar Nova Senha</label>
        <input type="password" id="confirmarSenha" placeholder="Digite novamente">
      </div>
      <button class="btn-reset" onclick="redefinirSenha()">
        <i class="fas fa-check btn-reset-icon"></i>Redefinir Senha
      </button>
    </div>
  </div>
  <a href="login.html" class="back-link">← Voltar ao Login</a>
</div>

<!-- TOAST -->
<div class="toast" id="toast"></div>

<script>
  function mostrarToast(mensagem, tipo = 'sucesso') {
    const toast = document.getElementById('toast');
    toast.textContent = mensagem;
    toast.className = 'toast ' + tipo;
    toast.classList.add('show');
    setTimeout(() => toast.classList.remove('show'), 3000);
  }

  function mostrarMensagem(texto, tipo) {
    const div = document.getElementById('mensagem');
    div.className = tipo;
    div.textContent = texto;
    div.style.display = 'block';
  }

  function getParametroUrl(nome) {
    const urlParams = new URLSearchParams(window.location.search);
    return urlParams.get(nome);
  }

  let tokenValido = null;
  let emailValido = null;

  window.onload = function() {
    const token = getParametroUrl('token');
    const email = getParametroUrl('email');

    if (!token || !email) {
      mostrarMensagem('Link inválido ou expirado!', 'error');
      document.getElementById('formRedefinir').style.display = 'none';
      return;
    }

    const resetTokens = JSON.parse(localStorage.getItem('resetTokens') || '[]');
    const tokenEncontrado = resetTokens.find(t => t.token === token && t.email === email);

    if (!tokenEncontrado) {
      mostrarMensagem('Link inválido ou expirado!', 'error');
      document.getElementById('formRedefinir').style.display = 'none';
      return;
    }

    tokenValido = token;
    emailValido = email;
  };

  async function redefinirSenha() {
    const senha1 = document.getElementById('novaSenha').value;
    const senha2 = document.getElementById('confirmarSenha').value;

    if (!senha1 || !senha2) {
      mostrarMensagem('Preencha todos os campos!', 'error');
      return;
    }

    if (senha1.length < 4) {
      mostrarMensagem('Senha muito curta!', 'error');
      return;
    }

    if (senha1 !== senha2) {
      mostrarMensagem('As senhas não coincidem!', 'error');
      return;
    }

    if (typeof ZCoreAPI !== 'undefined') {
      await ZCoreAPI.init();
      if (ZCoreAPI._online) {
        try {
          await ZCoreAPI.resetPassword({ token: tokenValido, email: emailValido, senha: senha1 });
          mostrarMensagem('Senha redefinida com sucesso!', 'success');
          document.getElementById('formRedefinir').style.display = 'none';
          setTimeout(() => { window.location.href = 'login.html'; }, 2000);
          return;
        } catch (e) {
          mostrarMensagem(e.message, 'error');
          return;
        }
      }
    }

    const usuarios = JSON.parse(localStorage.getItem('usuarios') || '[]');
    const usuarioIndex = usuarios.findIndex(u => u.email === emailValido);

    if (usuarioIndex === -1) {
      mostrarMensagem('Usuário não encontrado!', 'error');
      return;
    }

    usuarios[usuarioIndex].senha = senha1;
    localStorage.setItem('usuarios', JSON.stringify(usuarios));

    const resetTokens = JSON.parse(localStorage.getItem('resetTokens') || '[]');
    const tokensAtualizados = resetTokens.filter(t => t.token !== tokenValido);
    localStorage.setItem('resetTokens', JSON.stringify(tokensAtualizados));

    mostrarMensagem('Senha redefinida com sucesso!', 'success');
    document.getElementById('formRedefinir').style.display = 'none';

    setTimeout(() => {
      window.location.href = 'login.html';
    }, 2000);
  }
</script>
<script src="../js/api.js"></script>
<script src="../js/tema.js"></script>

</body>
</html>

