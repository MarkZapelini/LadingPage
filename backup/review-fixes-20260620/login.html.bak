<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <script>(function(){try{var t=localStorage.getItem('zcore-theme');document.documentElement.setAttribute('data-theme',t==='dark'?'dark':'light');}catch(e){}})();</script>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login — Z-Core Eletrônicos</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link rel="stylesheet" href="../css/style.css">
  <link rel="stylesheet" href="../css/responsive.css">
  <link rel="stylesheet" href="../css/pages/login.css">
  <!-- Firebase SDK -->
  <script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-app-compat.js"></script>
  <script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-auth-compat.js"></script>
  <script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-firestore-compat.js"></script>
  <!-- EmailJS SDK -->
  <script src="https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js"></script>
</head>
<body>

<!-- NAV -->
<nav class="premium-header">
  <div class="header-container">
    <a href="../index.html" class="logo">
      <span class="logo-symbol">Z</span>
      <span class="logo-text">Core</span>
    </a>

    <button class="menu-toggle-premium" id="mobileMenuBtn" aria-label="Abrir menu">
      <i class="fas fa-bars"></i>
    </button>
    
    <ul class="nav-links" id="navLinks">
      <li><a href="../index.html">Início</a></li>
      <li><a href="../index.html#produtos">Produtos</a></li>
      <li><a href="../index.html#ofertas">Ofertas</a></li>
      <li><a href="#">Contato</a></li>
    </ul>

    <div class="nav-actions">
      <button type="button" class="theme-toggle" aria-label="Ativar modo escuro" title="Modo escuro">
        <i class="fas fa-sun theme-icon-light"></i>
        <i class="fas fa-moon theme-icon-dark"></i>
      </button>

      <div id="authButtons" class="auth-group">
        <a href="login.html" class="link-login active">Entrar</a>
        <a href="cadastro.html" class="btn-register-premium">Cadastre-se</a>
      </div>

      <div id="userLogged" class="user-group login-user-group-hidden">
        <div class="user-info-premium">
          <div class="user-avatar-premium" id="userAvatar">U</div>
          <span class="user-name-premium" id="userName">Usuário</span>
        </div>
        <button class="btn-logout-premium" onclick="fazerLogout()"><i class="fas fa-sign-out-alt"></i></button>
      </div>
    </div>
  </div>
</nav>

<!-- LOGIN -->
<section class="auth-section">
  <div class="auth-container">
    <a href="../index.html" class="back-link">← Voltar à loja</a>
    
    <h1 class="auth-title">Entrar na sua Conta</h1>
    
    <div class="auth-card">
      <form id="loginForm" onsubmit="fazerLogin(event)">
        <div class="form-group">
          <label>E-mail</label>
          <input type="email" id="loginEmail" placeholder="seu@email.com" required>
        </div>
        <div class="form-group">
          <label>Senha</label>
          <input type="password" id="loginSenha" placeholder="Sua senha" required>
        </div>
        <button type="submit" class="btn-auth">Entrar</button>
      </form>
      
      <button type="button" class="btn-google" onclick="loginGoogle()">
        <span>🔵</span> Entrar com Google
      </button>
      
      <div class="auth-divider">
        <span>ou</span>
      </div>
      
      <p class="auth-link auth-link-compact">
        Esqueceu a senha? 
        <a href="#" onclick="abrirModalRecuperar()">Recuperar</a>
      </p>
      <p class="auth-link">
        Não tem uma conta? 
        <a href="cadastro.html">Cadastre-se</a>
      </p>
    </div>
  </div>
</section>

<!-- FOOTER -->
<footer class="footer-full">
  <div class="footer-content">
    <div class="footer-section">
      <div class="footer-logo">
        <span class="logo-symbol">Z</span>
        <span class="logo-text">Core</span>
      </div>
      <p class="footer-desc">A sua loja de eletrônicos com os melhores preços, garantia e entrega rápida em todo o Brasil.</p>
      <div class="social-links">
        <a href="#" class="social-icon">📘</a>
        <a href="#" class="social-icon">📷</a>
        <a href="#" class="social-icon">🐦</a>
        <a href="#" class="social-icon">📺</a>
      </div>
    </div>

    <div class="footer-section">
      <h4>Institucional</h4>
      <a href="sobre.html">Sobre Nós</a>
      <a href="#">Política de Privacidade</a>
      <a href="#">Termos de Uso</a>
      <a href="#">Trabalhe Conosco</a>
    </div>

    <div class="footer-section">
      <h4>Ajuda</h4>
      <a href="faq.html">FAQ</a>
      <a href="#">Trocas e Devoluções</a>
      <a href="#">Entregas</a>
      <a href="#">Garantia</a>
    </div>

    <div class="footer-section">
      <h4>Contato</h4>
      <p class="contact-item">📧 contato@zcore.com.br</p>
      <p class="contact-item">📞 (11) 99999-9999</p>
      <p class="contact-item">📍 São Paulo, SP</p>
    </div>
  </div>
  
  <div class="footer-bottom">
    <p>© 2025 Z-Core Eletrônicos. Todos os direitos reservados.</p>
    <div class="payment-methods">
      <span>💳</span>
      <span>💳</span>
      <span>💰</span>
      <span>📱</span>
    </div>
  </div>
</footer>

<!-- MODAL DE RECUPERAÇÃO DE SENHA -->
<div class="modal-overlay login-modal-overlay" id="modalRecuperarSenha">
  <div class="modal login-modal">
    <div class="login-modal-header">
      <div>
        <h2 class="login-modal-title">Recuperar Senha</h2>
        <p class="login-modal-subtitle">Digite seu e-mail para receber o link de recuperação</p>
      </div>
      <button onclick="fecharModalRecuperar()" class="login-modal-close">×</button>
    </div>
    
    <div id="step1">
      <div class="form-group login-modal-step">
        <label class="login-modal-label">E-mail Cadastrado</label>
        <input type="email" id="recuperarEmail" placeholder="seu@email.com" class="login-modal-input">
      </div>
      
      <button onclick="enviarLinkRecuperacao()" class="login-modal-primary-btn">
        <i class="fas fa-paper-plane login-modal-icon"></i>Enviar Link de Recuperação
      </button>
    </div>
    
    <div id="step2" class="login-modal-success">
      <div class="login-modal-success-icon">✅</div>
      <h3 class="login-modal-success-title">Link Enviado!</h3>
      <p class="login-modal-success-text">Verifique seu e-mail para redefinir sua senha!</p>
      <button onclick="fecharModalRecuperar()" class="login-modal-secondary-btn">
        Voltar ao Login
      </button>
    </div>
  </div>
</div>

<!-- TOAST -->
<div class="toast" id="toast"></div>

<script>
  function mostrarToast(mensagem, tipo = 'sucesso') {
    const toast = document.getElementById('toast');
    toast.textContent = mensagem;
    toast.className = 'toast ' + tipo;
    toast.classList.add('show');
    
    setTimeout(() => {
      toast.classList.remove('show');
    }, 3000);
  }

  // === CONFIGURAÇÃO DO FIREBASE ===
  const firebaseConfig = {
    apiKey: "AIzaSyA7gHgpS2dBrIa2dJamylsg9DUdgOHt3Sk",
    authDomain: "pg-de-vendas.firebaseapp.com",
    databaseURL: "https://pg-de-vendas-default-rtdb.firebaseio.com",
    projectId: "pg-de-vendas",
    storageBucket: "pg-de-vendas.firebasestorage.app",
    messagingSenderId: "803403474499",
    appId: "1:803403474499:web:e729b5b49b75dfa4cd16f6",
    measurementId: "G-5LPWHGFWK5"
  };

  // Inicializa o Firebase
  firebase.initializeApp(firebaseConfig);
  const auth = firebase.auth();
  const db = firebase.firestore();
  
  // === CONFIGURAÇÃO DO EMAILJS ===
  const EMAILJS_PUBLIC_KEY = '3cCe-LruV3ESz2E_K';
  const EMAILJS_SERVICE_ID = 'service_5r5zkyc';
  const EMAILJS_TEMPLATE_ID = '3cCe-LruV3ESz2E_K';
  
  // Inicializa o EmailJS
  if (typeof emailjs !== 'undefined') {
    emailjs.init(EMAILJS_PUBLIC_KEY);
  }
  
  // === FUNÇÕES DO FIRESTORE ===
  // Salvar usuário no Firestore
  async function salvarUsuarioFirestore(usuario) {
    try {
      await db.collection('usuarios').doc(usuario.id.toString()).set(usuario);
      console.log('✅ Usuário salvo no Firestore!');
    } catch (error) {
      console.error('❌ Erro ao salvar usuário:', error);
    }
  }
  
  // Obter usuário do Firestore
  async function getUsuarioFirestore(email) {
    try {
      const snapshot = await db.collection('usuarios').where('email', '==', email).get();
      if (!snapshot.empty) {
        return snapshot.docs[0].data();
      }
      return null;
    } catch (error) {
      console.error('❌ Erro ao buscar usuário:', error);
      return null;
    }
  }

  // Login com Google
  function loginGoogle() {
    const provider = new firebase.auth.GoogleAuthProvider();
    auth.signInWithPopup(provider)
      .then((result) => {
        const user = result.user;
        
        // Salva o usuário no localStorage
        const usuarioGoogle = {
          id: user.uid,
          nome: user.displayName,
          email: user.email,
          foto: user.photoURL,
          pedidos: []
        };
        
        // Verifica se o usuário já existe no nosso sistema
        let usuarios = JSON.parse(localStorage.getItem('usuarios') || '[]');
        let usuarioExistente = usuarios.find(u => u.email === usuarioGoogle.email);
        
        if (!usuarioExistente) {
          usuarios.push(usuarioGoogle);
          localStorage.setItem('usuarios', JSON.stringify(usuarios));
          // Salva o novo usuário no Firestore
          salvarUsuarioFirestore(usuarioGoogle);
        }
        
        localStorage.setItem('usuarioLogado', JSON.stringify(usuarioExistente || usuarioGoogle));
        mostrarToast('✅ Login com Google realizado com sucesso!');
        setTimeout(() => {
          window.location.href = '../index.html';
        }, 1500);
      })
      .catch((error) => {
        console.error('Erro no login:', error);
        mostrarToast('❌ Erro ao fazer login com Google!', 'erro');
      });
  }

  function verificarLogin() {
    const usuarioLogado = JSON.parse(localStorage.getItem('usuarioLogado'));
    const authButtons = document.getElementById('authButtons');
    const userLogged = document.getElementById('userLogged');
    const userAvatar = document.getElementById('userAvatar');
    
    if (usuarioLogado) {
      authButtons.style.display = 'none';
      userLogged.style.display = 'flex';
      document.getElementById('userName').textContent = usuarioLogado.nome.split(' ')[0];
      
      if (userAvatar) {
        if (usuarioLogado.avatar) {
          userAvatar.style.backgroundImage = `url(${usuarioLogado.avatar})`;
          userAvatar.style.backgroundSize = 'cover';
          userAvatar.style.backgroundPosition = 'center';
          userAvatar.textContent = '';
        } else {
          userAvatar.textContent = (usuarioLogado.nome || 'U')[0].toUpperCase();
          userAvatar.style.backgroundImage = '';
        }
      }
    } else {
      authButtons.style.display = 'flex';
      userLogged.style.display = 'none';
      if (userAvatar) userAvatar.textContent = 'U';
    }
  }

  function fazerLogout() {
    if (typeof ZCoreAPI !== 'undefined') ZCoreAPI.logout();
    localStorage.removeItem('usuarioLogado');
    verificarLogin();
    mostrarToast('✅ Você saiu da sua conta!');
  }

  function abrirModalRecuperar() {
    document.getElementById('modalRecuperarSenha').style.display = 'flex';
    document.getElementById('step1').style.display = 'block';
    document.getElementById('step2').style.display = 'none';
    document.getElementById('recuperarEmail').value = '';
  }

  function fecharModalRecuperar() {
    document.getElementById('modalRecuperarSenha').style.display = 'none';
  }

  function gerarToken() {
    return Date.now().toString(36) + Math.random().toString(36).substr(2);
  }

  function enviarLinkRecuperacao() {
    const email = document.getElementById('recuperarEmail').value.trim();
    if (!email) {
      mostrarToast('❌ Digite um e-mail!', 'erro');
      return;
    }

    const usuarios = JSON.parse(localStorage.getItem('usuarios') || '[]');
    const usuario = usuarios.find(u => u.email === email);

    if (!usuario) {
      mostrarToast('❌ E-mail não cadastrado!', 'erro');
      return;
    }

    const token = gerarToken();
    const resetTokens = JSON.parse(localStorage.getItem('resetTokens') || '[]');
    
    resetTokens.push({
      token: token,
      email: email,
      dataCriacao: new Date().toISOString()
    });
    
    localStorage.setItem('resetTokens', JSON.stringify(resetTokens));

    const linkRecuperacao = new URL(
      `reset-password.html?token=${token}&email=${encodeURIComponent(email)}`,
      window.location.href
    ).toString();

    if (typeof emailjs !== 'undefined') {
      const templateParams = {
        to_email: email,
        to_name: usuario.nome || 'Cliente',
        reset_link: linkRecuperacao
      };

      emailjs.send(EMAILJS_SERVICE_ID, EMAILJS_TEMPLATE_ID, templateParams)
        .then(function(response) {
          console.log('E-mail enviado com sucesso!', response.status, response.text);
          document.getElementById('step1').style.display = 'none';
          document.getElementById('step2').style.display = 'block';
        }, function(error) {
          console.log('Erro ao enviar e-mail:', error);
          mostrarToast('❌ Erro ao enviar e-mail!', 'erro');
        });
    } else {
      console.log('Link de recuperação:', linkRecuperacao);
      document.getElementById('step1').style.display = 'none';
      document.getElementById('step2').style.display = 'block';
    }
  }

  // Fechar modal ao clicar no overlay
  document.getElementById('modalRecuperarSenha').addEventListener('click', function(e) {
    if (e.target === this) {
      fecharModalRecuperar();
    }
  });

  async function fazerLogin(e) {
    e.preventDefault();
    console.log('🔐 Iniciando processo de login...');
    
    const email = document.getElementById('loginEmail').value;
    const senha = document.getElementById('loginSenha').value;
    
    console.log('📧 Email informado:', email);
    console.log('🔑 Senha informada:', senha);

    // 1. Tenta login via API primeiro
    if (typeof ZCoreAPI !== 'undefined') {
      console.log('📡 Tentando login via API...');
      await ZCoreAPI.init();
      if (ZCoreAPI._online) {
        try {
          const data = await ZCoreAPI.login({ email, senha });
          ZCoreAPI.saveSession(data);
          mostrarToast('✅ Login realizado com sucesso!');
          setTimeout(() => { window.location.href = '../index.html'; }, 1500);
          return;
        } catch (err) {
          console.error('❌ Erro na API:', err);
          mostrarToast('❌ ' + err.message, 'erro');
          return;
        }
      } else {
        console.log('📡 API offline, tentando Firestore...');
      }
    }

    // 2. Tenta buscar no Firebase Firestore
    try {
      console.log('🔍 Tentando login via Firestore...');
      const usuarioFirestore = await getUsuarioFirestore(email);
      if (usuarioFirestore && usuarioFirestore.senha === senha) {
        console.log('✅ Usuário encontrado no Firestore!');
        
        // Salva no localStorage local para uso offline
        let usuariosLocal = JSON.parse(localStorage.getItem('usuarios') || '[]');
        const usuarioExistenteLocal = usuariosLocal.find(u => u.email === email);
        if (!usuarioExistenteLocal) {
          usuariosLocal.push(usuarioFirestore);
          localStorage.setItem('usuarios', JSON.stringify(usuariosLocal));
        }
        
        localStorage.setItem('usuarioLogado', JSON.stringify(usuarioFirestore));
        mostrarToast('✅ Login realizado com sucesso!');
        setTimeout(() => { window.location.href = '../index.html'; }, 1500);
        return;
      }
    } catch (error) {
      console.error('❌ Erro ao buscar no Firestore:', error);
    }

    // 3. Última tentativa: localStorage local
    console.log('👥 Tentando login via localStorage local...');
    const usuarios = JSON.parse(localStorage.getItem('usuarios') || '[]');
    console.log('👥 Usuários no localStorage:', usuarios);
    
    const usuario = usuarios.find(u => u.email === email && u.senha === senha);
    console.log('👤 Usuário encontrado:', usuario);
    
    if (usuario) {
      localStorage.setItem('usuarioLogado', JSON.stringify(usuario));
      console.log('✅ Sessão salva! Redirecionando...');
      mostrarToast('✅ Login realizado com sucesso!');
      setTimeout(() => { window.location.href = '../index.html'; }, 1500);
    } else {
      console.error('❌ Usuário ou senha incorretos!');
      mostrarToast('❌ E-mail ou senha incorretos!', 'erro');
    }
  }

  window.onload = verificarLogin;
</script>
<script src="../js/api.js"></script>
<script src="../js/tema.js"></script>
<script src="../js/menu-mobile.js"></script>
<script src="../js/seed-local-users.js"></script>

</body>
</html>
