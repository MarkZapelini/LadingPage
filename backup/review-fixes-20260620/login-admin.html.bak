<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <script>(function(){try{var t=localStorage.getItem('zcore-theme');document.documentElement.setAttribute('data-theme',t==='dark'?'dark':'light');}catch(e){}})();</script>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login Admin — Z-Core</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link rel="stylesheet" href="../css/admin/login-admin.css">
</head>
<body>

<div class="login-theme-wrap">
  <button type="button" class="theme-toggle" id="loginThemeToggle" aria-label="Ativar modo escuro" title="Modo escuro">
    <i class="fas fa-sun theme-icon-light" aria-hidden="true"></i>
    <i class="fas fa-moon theme-icon-dark" aria-hidden="true"></i>
  </button>
</div>

<div class="login-box">
  <div class="login-header">
    <div class="login-logo"><span>Z</span>-Core</div>
    <div class="login-subtitle">Painel de Administração</div>
  </div>

  <div class="form-group">
    <label>Usuário Admin</label>
    <input type="text" id="adminUser" placeholder="Digite o usuário" autocomplete="username">
  </div>

  <div class="form-group">
    <label>Senha</label>
    <input type="password" id="adminPass" placeholder="Digite a senha" autocomplete="current-password">
  </div>

  <button class="btn-login" onclick="fazerLoginAdmin()">
    <i class="fas fa-sign-in-alt"></i> Entrar no Painel
  </button>

  <a href="../index.html" class="back-link">← Voltar à loja a </a>
</div>

<div class="toast" id="toast"></div>

<script>
  function mostrarToast(mensagem, tipo = 'sucesso') {
    const toast = document.getElementById('toast');
    toast.textContent = mensagem;
    toast.className = 'toast ' + tipo;
    toast.classList.add('show');
    
    setTimeout(() => {
      toast.classList.remove('show');
    }, 3000);
  }

  // Credenciais padrão do admin
  const CREDENCIAIS_PADRAO = {
    usuario: 'admin',
    senha: 'admin123'
  };

  async function fazerLoginAdmin() {
    const usuario = document.getElementById('adminUser').value.trim();
    const senha = document.getElementById('adminPass').value;

    if (typeof ZCoreAPI !== 'undefined') {
      await ZCoreAPI.init();
      if (ZCoreAPI._online) {
        try {
          const data = await ZCoreAPI.loginAdmin({ usuario, senha });
          ZCoreAPI.saveAdminSession(data);
          mostrarToast('✅ Login realizado com sucesso!');
          setTimeout(() => { window.location.href = 'admin-full.html'; }, 1000);
          return;
        } catch (err) {
          mostrarToast('❌ ' + err.message, 'erro');
          return;
        }
      }
    }

    if (usuario === CREDENCIAIS_PADRAO.usuario && senha === CREDENCIAIS_PADRAO.senha) {
      const adminLogado = {
        logado: true,
        usuario: usuario,
        data: new Date().toLocaleDateString('pt-BR'),
        dataLogin: new Date().toISOString()
      };
      localStorage.setItem('adminLogado', JSON.stringify(adminLogado));
      
      // Garantir que exista um perfil admin
      if (!localStorage.getItem('adminProfile')) {
        localStorage.setItem('adminProfile', JSON.stringify({
          nome: 'Admin',
          avatar: 'AD',
          cor: '#A020F0',
          foto: null
        }));
      }
      
      mostrarToast('✅ Login realizado com sucesso!');
      setTimeout(() => { window.location.href = 'admin-full.html'; }, 1000);
    } else {
      mostrarToast('❌ Usuário ou senha incorretos!', 'erro');
    }
  }

  // Enter para login
  document.getElementById('adminPass').addEventListener('keypress', function(e) {
    if (e.key === 'Enter') {
      fazerLoginAdmin();
    }
  });

  // Verificar se já está logado
  window.onload = async function() {
    if (typeof ZCoreAPI !== 'undefined') {
      await ZCoreAPI.init();
      if (ZCoreAPI._online && ZCoreAPI.isAdminLoggedIn()) {
        window.location.href = 'admin-full.html';
        return;
      }
    }

    const adminLogado = JSON.parse(localStorage.getItem('adminLogado'));
    if (adminLogado && adminLogado.logado) {
      window.location.href = 'admin-full.html';
    }
  };

  // Theme toggle no login
  document.getElementById('loginThemeToggle').addEventListener('click', function() {
    const current = document.documentElement.getAttribute('data-theme');
    const next = current === 'dark' ? 'light' : 'dark';
    document.documentElement.setAttribute('data-theme', next);
    localStorage.setItem('zcore-theme', next);
  });
</script>
<script src="../js/api.js"></script>
<script src="../js/tema.js"></script>

</body>
</html>
