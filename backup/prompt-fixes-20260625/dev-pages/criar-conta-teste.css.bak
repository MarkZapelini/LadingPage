body {
  font-family: Poppins, sans-serif;
  max-width: 600px;
  margin: 40px auto;
  padding: 20px;
  background: #0a0a0a;
  color: #fff;
}

.card {
  background: #111520;
  padding: 30px;
  border-radius: 20px;
  border: 1px solid #2a2a2a;
}

h1 {
  color: #a020f0;
}

.info {
  background: #1a1d26;
  padding: 20px;
  border-radius: 12px;
  margin: 20px 0;
}

.success {
  color: #00c9a7;
  font-weight: bold;
}

button {
  background: linear-gradient(135deg, #a020f0, #7a17b5);
  color: #fff;
  border: none;
  padding: 14px 24px;
  border-radius: 12px;
  font-size: 16px;
  cursor: pointer;
}

.cta-list {
  margin: 20px 0;
  padding-left: 20px;
}

.cta-link {
  color: #a020f0;
}
