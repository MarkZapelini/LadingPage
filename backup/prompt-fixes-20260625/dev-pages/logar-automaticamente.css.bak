body {
  font-family: Poppins, sans-serif;
  max-width: 600px;
  margin: 80px auto;
  padding: 20px;
  background: #0a0a0a;
  color: #fff;
  text-align: center;
}

.card {
  background: #111520;
  padding: 40px;
  border-radius: 20px;
  border: 1px solid #2a2a2a;
}

h1 {
  color: #a020f0;
}

.success {
  color: #00c9a7;
  font-size: 18px;
  font-weight: bold;
}

button {
  background: linear-gradient(135deg, #a020f0, #7a17b5);
  color: #fff;
  border: none;
  padding: 16px 32px;
  border-radius: 12px;
  font-size: 18px;
  cursor: pointer;
  margin: 10px;
}

.btn-success {
  background: linear-gradient(135deg, #00c9a7, #00997a);
}

.info {
  text-align: left;
  background: #1a1d26;
  padding: 20px;
  border-radius: 12px;
  margin: 20px 0;
}

.status-wrap {
  margin-top: 30px;
}
