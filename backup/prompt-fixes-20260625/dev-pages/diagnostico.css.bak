body {
  font-family: Poppins, sans-serif;
  max-width: 800px;
  margin: 40px auto;
  padding: 20px;
  background: #0a0a0a;
  color: #fff;
}

.card {
  background: #111520;
  padding: 30px;
  border-radius: 20px;
  border: 1px solid #2a2a2a;
  margin-bottom: 20px;
}

h1 {
  color: #a020f0;
}

h2 {
  color: #00c9a7;
}

.item {
  background: #1a1d26;
  padding: 15px;
  border-radius: 10px;
  margin: 10px 0;
}

.success {
  color: #00c9a7;
}

.error {
  color: #ff4d4d;
}

button {
  background: linear-gradient(135deg, #a020f0, #7a17b5);
  color: #fff;
  border: none;
  padding: 14px 24px;
  border-radius: 12px;
  font-size: 16px;
  cursor: pointer;
  margin: 5px;
}

.btn-success {
  background: linear-gradient(135deg, #00c9a7, #00997a);
}

pre {
  background: #0d0f14;
  padding: 15px;
  border-radius: 10px;
  overflow: auto;
}

.diagnostico-pre {
  margin-top: 8px;
  font-size: 12px;
}

.diagnostico-account-card {
  margin-top: 10px;
  padding: 10px;
  background: #1a1d26;
  border-radius: 8px;
}

.diagnostico-login-note {
  margin-top: 15px;
}
