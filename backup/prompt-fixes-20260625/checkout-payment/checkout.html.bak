<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <script>(function(){try{var t=localStorage.getItem('zcore_theme')||localStorage.getItem('zcore-theme');if(t){localStorage.setItem('zcore_theme',t);localStorage.removeItem('zcore-theme');}document.documentElement.setAttribute('data-theme',t==='dark'?'dark':'light');}catch(e){}})();</script>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Checkout — Z-Core Eletrônicos</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link rel="stylesheet" href="../css/style.css">
  <link rel="stylesheet" href="../css/pages/checkout.css">
  <!-- Firebase SDK -->
  <script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-app-compat.js"></script>
  <script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-auth-compat.js"></script>
  <script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-firestore-compat.js"></script>
  <script src="../js/firebase-config.js"></script>
</head>
<body>

<nav class="premium-header">
  <div class="header-container">
    <a href="../index.html" class="logo">
      <span class="logo-symbol">Z</span>
      <span class="logo-text">Core</span>
    </a>

    <button class="menu-toggle-premium" id="mobileMenuBtn" aria-label="Abrir menu">
      <i class="fas fa-bars"></i>
    </button>
    
    <ul class="nav-links" id="navLinks">
      <li><a href="../index.html">Início</a></li>
      <li><a href="../index.html#produtos">Produtos</a></li>
      <li><a href="../index.html#ofertas">Ofertas</a></li>
      <li><a href="#">Contato</a></li>
    </ul>

    <div class="nav-actions">
      <button type="button" class="theme-toggle" aria-label="Ativar modo escuro" title="Modo escuro">
        <i class="fas fa-sun theme-icon-light"></i>
        <i class="fas fa-moon theme-icon-dark"></i>
      </button>

      <div id="authButtons" class="auth-group">
        <a href="login.html" class="link-login">Entrar</a>
        <a href="cadastro.html" class="btn-register-premium">Cadastre-se</a>
      </div>

      <div id="userLogged" class="user-group checkout-user-group-hidden">
        <div class="user-info-premium">
          <div class="user-avatar-premium" id="userAvatar">U</div>
          <span class="user-name-premium" id="userName">Usuário</span>
        </div>
        <button class="btn-logout-premium" onclick="fazerLogout()"><i class="fas fa-sign-out-alt"></i></button>
      </div>
    </div>
  </div>
</nav>

<main class="checkout-main">
  <div class="checkout-wrapper">
    <div class="checkout-header-premium">
      <a href="../index.html" class="back-link-premium">
        <i class="fas fa-arrow-left"></i> Voltar à loja
      </a>
      <h1 class="premium-title">Finalizar Compra</h1>
      <p class="premium-subtitle">Complete seus dados para garantir sua tecnologia high-end.</p>
    </div>

    <div class="checkout-grid-premium">
      <!-- FORMULÁRIO -->
      <div class="checkout-form-premium">
        <div class="checkout-card-premium reveal-volt">
          <div class="card-header-premium">
            <div class="step-badge">01</div>
            <h3>Dados Pessoais</h3>
          </div>
          <div class="form-grid-premium">
            <div class="form-group-premium full">
              <label>Nome Completo</label>
              <input type="text" id="checkoutNome" placeholder="Ex: Juliano Silva" required>
            </div>
            <div class="form-group-premium">
              <label>CPF</label>
              <input type="text" id="checkoutCpf" placeholder="000.000.000-00">
            </div>
            <div class="form-group-premium">
              <label>Telefone</label>
              <input type="text" id="checkoutTelefone" placeholder="(11) 99999-9999">
            </div>
            <div class="form-group-premium full">
              <label>E-mail</label>
              <input type="email" id="checkoutEmail" placeholder="seu@email.com">
            </div>
          </div>
        </div>

        <div class="checkout-card-premium reveal-volt delay-1">
          <div class="card-header-premium">
            <div class="step-badge">02</div>
            <h3>Endereço de Entrega</h3>
          </div>
          <div class="form-grid-premium">
            <div class="form-group-premium">
              <label>CEP</label>
              <div class="input-with-action">
                <input type="text" id="checkoutCep" placeholder="00000-000">
                <button class="btn-zip">Buscar</button>
              </div>
            </div>
            <div class="form-group-premium full">
              <label>Logradouro</label>
              <input type="text" id="checkoutLogradouro" placeholder="Rua, Avenida, etc.">
            </div>
            <div class="form-group-premium">
              <label>Número</label>
              <input type="text" id="checkoutNumero" placeholder="123">
            </div>
            <div class="form-group-premium">
              <label>Complemento</label>
              <input type="text" id="checkoutComplemento" placeholder="Apto, Bloco, etc.">
            </div>
            <div class="form-group-premium">
              <label>Bairro</label>
              <input type="text" id="checkoutBairro" placeholder="Seu bairro">
            </div>
            <div class="form-group-premium">
              <label>Cidade</label>
              <input type="text" id="checkoutCidade" placeholder="Sua cidade">
            </div>
          </div>
        </div>

        <div class="checkout-card-premium reveal-volt delay-2">
          <div class="card-header-premium">
            <div class="step-badge">03</div>
            <h3>Método de Pagamento</h3>
          </div>
          <div class="payment-selector-premium">
            <label class="payment-card active">
              <input type="radio" name="payment" value="credito" checked>
              <div class="pay-icon"><i class="fas fa-credit-card"></i></div>
              <div class="pay-info">
                <span class="pay-title">Cartão de Crédito</span>
                <span class="pay-sub">Em até 12x sem juros</span>
              </div>
            </label>
            <label class="payment-card">
              <input type="radio" name="payment" value="pix">
              <div class="pay-icon"><i class="fab fa-pix"></i></div>
              <div class="pay-info">
                <span class="pay-title">Pix</span>
                <span class="pay-sub">Aprovação instantânea</span>
              </div>
            </label>
            <label class="payment-card">
              <input type="radio" name="payment" value="boleto">
              <div class="pay-icon"><i class="fas fa-barcode"></i></div>
              <div class="pay-info">
                <span class="pay-title">Boleto</span>
                <span class="pay-sub">Vencimento em 3 dias</span>
              </div>
            </label>
          </div>
          
          <div class="card-details-premium">
            <div class="form-group-premium full">
              <label>Número do Cartão</label>
              <input type="text" placeholder="0000 0000 0000 0000">
            </div>
            <div class="form-group-premium full">
              <label>Nome no Cartão</label>
              <input type="text" placeholder="Como impresso no cartão">
            </div>
            <div class="form-group-premium">
              <label>Validade</label>
              <input type="text" placeholder="MM/AA">
            </div>
            <div class="form-group-premium">
              <label>CVV</label>
              <input type="text" placeholder="123">
            </div>
          </div>
        </div>
      </div>

      <!-- RESUMO -->
      <div class="checkout-sidebar-premium">
        <div class="summary-card-premium sticky-summary reveal-volt delay-3">
          <h3>Resumo do Pedido</h3>
          <div id="summaryItems" class="summary-items-premium"></div>
          
          <div class="coupon-box-premium">
            <input type="text" id="couponInput" placeholder="Cupom de desconto">
            <button onclick="aplicarCupom()">Aplicar</button>
          </div>
          <div id="couponMessage" class="coupon-msg"></div>

          <div class="price-breakdown">
            <div class="price-row">
              <span>Subtotal</span>
              <span id="summarySubtotal">R$ 0,00</span>
            </div>
            <div class="price-row discount checkout-discount-hidden" id="discountRow">
              <span>Desconto</span>
              <span id="summaryDiscount">- R$ 0,00</span>
            </div>
            <div class="price-row">
              <span>Frete</span>
              <span class="free-shipping">Grátis</span>
            </div>
            <div class="price-total">
              <span>Total</span>
              <strong id="summaryTotal">R$ 0,00</strong>
            </div>
          </div>

          <button class="btn-confirm-premium" onclick="confirmarPedido()">
            Finalizar Pagamento
            <i class="fas fa-shield-alt"></i>
          </button>
          
          <div class="secure-checkout">
            <i class="fas fa-lock"></i>
            <span>Ambiente 100% Seguro & Criptografado</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</main>

<!-- FOOTER -->
<footer class="footer-full">
  <div class="footer-content">
    <div class="footer-section">
      <div class="footer-logo"><span>Z</span>-Core</div>
      <p class="footer-desc">A sua loja de eletrônicos com os melhores preços, garantia e entrega rápida em todo o Brasil.</p>
      <div class="social-links">
        <a href="#" class="social-icon">📘</a>
        <a href="#" class="social-icon">📷</a>
        <a href="#" class="social-icon">🐦</a>
        <a href="#" class="social-icon">📺</a>
      </div>
    </div>

    <div class="footer-section">
      <h4>Institucional</h4>
      <a href="sobre.html">Sobre Nós</a>
      <a href="#">Política de Privacidade</a>
      <a href="#">Termos de Uso</a>
      <a href="#">Trabalhe Conosco</a>
    </div>

    <div class="footer-section">
      <h4>Ajuda</h4>
      <a href="faq.html">FAQ</a>
      <a href="#">Trocas e Devoluções</a>
      <a href="#">Entregas</a>
      <a href="#">Garantia</a>
    </div>

    <div class="footer-section">
      <h4>Contato</h4>
      <p class="contact-item">📧 contato@zcore.com.br</p>
      <p class="contact-item">📞 (11) 99999-9999</p>
      <p class="contact-item">📍 São Paulo, SP</p>
    </div>
  </div>
  
  <div class="footer-bottom">
    <p>© 2025 Z-Core Eletrônicos. Todos os direitos reservados.</p>
    <div class="payment-methods">
      <span>💳</span>
      <span>💳</span>
      <span>💰</span>
      <span>📱</span>
    </div>
  </div>
</footer>

<!-- TOAST -->
<div class="toast" id="toast"></div>

<script>
  // Cupons disponíveis
  const cuponsDisponiveis = {
    'BEMVINDO10': { tipo: 'percentual', valor: 10, descricao: '10% de desconto' },
    'FRETEGRATIS': { tipo: 'frete', valor: 0, descricao: 'Frete grátis' },
    'DESCONTO50': { tipo: 'percentual', valor: 50, descricao: '50% de desconto' },
    'PIX15': { tipo: 'percentual', valor: 15, descricao: '15% de desconto no Pix' }
  };
  
  let cupomAplicado = null;
  let subtotalOriginal = 0;
  
  function mostrarToast(mensagem, tipo = 'sucesso') {
    const toast = document.getElementById('toast');
    toast.textContent = mensagem;
    toast.className = 'toast ' + tipo;
    toast.classList.add('show');
    
    setTimeout(() => {
      toast.classList.remove('show');
    }, 3000);
  }
  
  function aplicarCupom() {
    const input = document.getElementById('couponInput');
    const mensagem = document.getElementById('couponMessage');
    const cupom = input.value.toUpperCase().trim();
    
    if (!cupom) {
      mensagem.textContent = '❌ Digite um cupom!';
      mensagem.style.color = '#ef4444';
      return;
    }
    
    if (cuponsDisponiveis[cupom]) {
      cupomAplicado = cuponsDisponiveis[cupom];
      mensagem.textContent = '✅ Cupom aplicado: ' + cupomAplicado.descricao;
      mensagem.style.color = '#22c55e';
      atualizarResumo();
    } else {
      cupomAplicado = null;
      mensagem.textContent = '❌ Cupom inválido!';
      mensagem.style.color = '#ef4444';
      atualizarResumo();
    }
  }

  // === CONFIGURACAO DO FIREBASE ===
  const firebaseApp = typeof window.initZCoreFirebase === 'function' ? window.initZCoreFirebase() : null;
  const auth = firebaseApp ? firebase.auth() : null;
  const db = firebaseApp ? firebase.firestore() : null;
  
  // === FUNÇÕES DO FIRESTORE ===
  // Salvar pedido no Firestore
  async function salvarPedidoFirestore(pedido, usuarioId) {
    try {
      await db.collection('pedidos').doc(pedido.id.toString()).set({
        ...pedido,
        usuarioId: usuarioId,
        createdAt: firebase.firestore.FieldValue.serverTimestamp()
      });
      console.log('✅ Pedido salvo no Firestore!');
    } catch (error) {
      console.error('❌ Erro ao salvar pedido:', error);
    }
  }

  function carregarResumo() {
    const cart = JSON.parse(localStorage.getItem('zcore_cart') || '[]');
    const summaryItems = document.getElementById('summaryItems');
    const summarySubtotal = document.getElementById('summarySubtotal');
    const summaryDiscount = document.getElementById('summaryDiscount');
    const discountRow = document.getElementById('discountRow');
    const summaryTotal = document.getElementById('summaryTotal');

    if (cart.length === 0) {
      summaryItems.innerHTML = '<p class="checkout-empty-message">Seu carrinho está vazio</p>';
      return;
    }

    let html = '';
    subtotalOriginal = 0;

    cart.forEach(item => {
      const subtotal = item.preco * item.quantidade;
      subtotalOriginal += subtotal;
      
      html += `
        <div class="summary-item-premium">
          <div class="item-visual-premium">${item.emoji}</div>
          <div class="item-details-premium">
            <div class="item-name-premium">${item.nome}</div>
            <div class="item-meta-premium">Qtd: ${item.quantidade} • R$ ${item.preco.toLocaleString('pt-BR')}</div>
          </div>
          <span class="item-price-premium">R$ ${subtotal.toLocaleString('pt-BR')}</span>
        </div>
      `;
    });

    summaryItems.innerHTML = html;
    atualizarResumo();
  }
  
  function atualizarResumo() {
    const summarySubtotal = document.getElementById('summarySubtotal');
    const summaryDiscount = document.getElementById('summaryDiscount');
    const discountRow = document.getElementById('discountRow');
    const summaryTotal = document.getElementById('summaryTotal');
    
    summarySubtotal.textContent = 'R$ ' + subtotalOriginal.toLocaleString('pt-BR');
    
    let desconto = 0;
    if (cupomAplicado && cupomAplicado.tipo === 'percentual') {
      desconto = subtotalOriginal * (cupomAplicado.valor / 100);
      discountRow.style.display = 'flex';
      summaryDiscount.textContent = '- R$ ' + desconto.toLocaleString('pt-BR');
    } else {
      discountRow.style.display = 'none';
    }
    
    const total = subtotalOriginal - desconto;
    summaryTotal.textContent = 'R$ ' + total.toLocaleString('pt-BR');
  }

  function verificarLogin() {
    const usuarioLogado = JSON.parse(localStorage.getItem('usuarioLogado'));
    const authButtons = document.getElementById('authButtons');
    const userLogged = document.getElementById('userLogged');
    
    if (usuarioLogado) {
      authButtons.style.display = 'none';
      userLogged.style.display = 'flex';
      document.getElementById('userName').textContent = usuarioLogado.nome.split(' ')[0];
      document.getElementById('userAvatar').textContent = usuarioLogado.nome[0].toUpperCase();
    } else {
      authButtons.style.display = 'flex';
      userLogged.style.display = 'none';
    }
  }

  function obterMetodoPagamento() {
    return document.querySelector('input[name="payment"]:checked')?.value || 'credito';
  }

  function obterDadosCheckout() {
    return {
      nome: document.getElementById('checkoutNome').value.trim(),
      cpf: document.getElementById('checkoutCpf').value.trim(),
      telefone: document.getElementById('checkoutTelefone').value.trim(),
      email: document.getElementById('checkoutEmail').value.trim(),
      endereco: {
        cep: document.getElementById('checkoutCep').value.trim(),
        logradouro: document.getElementById('checkoutLogradouro').value.trim(),
        numero: document.getElementById('checkoutNumero').value.trim(),
        complemento: document.getElementById('checkoutComplemento').value.trim(),
        bairro: document.getElementById('checkoutBairro').value.trim(),
        cidade: document.getElementById('checkoutCidade').value.trim()
      },
      paymentMethod: obterMetodoPagamento()
    };
  }

  function validarCheckout(dados) {
    if (!dados.nome || !dados.email) {
      return 'Preencha nome e e-mail para continuar.';
    }

    if (!dados.endereco.cep || !dados.endereco.logradouro || !dados.endereco.numero || !dados.endereco.bairro || !dados.endereco.cidade) {
      return 'Preencha o endereço de entrega completo.';
    }

    return '';
  }

  function preencherDadosUsuario() {
    const usuarioLogado = JSON.parse(localStorage.getItem('usuarioLogado') || 'null');
    if (!usuarioLogado) return;

    document.getElementById('checkoutNome').value = usuarioLogado.nome || '';
    document.getElementById('checkoutCpf').value = usuarioLogado.cpf || '';
    document.getElementById('checkoutTelefone').value = usuarioLogado.telefone || '';
    document.getElementById('checkoutEmail').value = usuarioLogado.email || '';
    document.getElementById('checkoutCep').value = usuarioLogado.cep || '';
    document.getElementById('checkoutLogradouro').value = usuarioLogado.rua || '';
    document.getElementById('checkoutNumero').value = usuarioLogado.numero || '';
    document.getElementById('checkoutComplemento').value = usuarioLogado.complemento || '';
    document.getElementById('checkoutBairro').value = usuarioLogado.bairro || '';
    document.getElementById('checkoutCidade').value = usuarioLogado.cidade || '';
  }

  function fazerLogout() {
    if (typeof ZCoreAPI !== 'undefined') ZCoreAPI.logout();
    localStorage.removeItem('usuarioLogado');
    verificarLogin();
    mostrarToast('✅ Você saiu da sua conta!');
  }

  // Criar pedido e iniciar pagamento
  async function confirmarPedido() {
    const usuarioLogado = JSON.parse(localStorage.getItem('usuarioLogado'));
    if (!usuarioLogado) {
      mostrarToast('❌ Você precisa estar logado para finalizar o pedido!', 'erro');
      setTimeout(() => { window.location.href = 'login.html'; }, 1500);
      return;
    }

    const cart = JSON.parse(localStorage.getItem('zcore_cart') || '[]');
    if (cart.length === 0) {
      mostrarToast('❌ Seu carrinho está vazio!', 'erro');
      return;
    }

    const dadosCheckout = obterDadosCheckout();
    const erroValidacao = validarCheckout(dadosCheckout);
    if (erroValidacao) {
      mostrarToast('❌ ' + erroValidacao, 'erro');
      return;
    }

    try {
      if (typeof ZCoreAPI !== 'undefined') {
        await ZCoreAPI.init();
        if (ZCoreAPI._online && localStorage.getItem('zcore_token')) {
          const order = await ZCoreAPI.createOrder({
            itens: cart,
            endereco: dadosCheckout.endereco,
            paymentMethod: dadosCheckout.paymentMethod,
            paymentStatus: 'pendente'
          });

          try {
            const paymentPreference = await ZCoreAPI.createPaymentPreference({
              items: cart,
              orderId: order.id
            });

            if (paymentPreference.sandbox_init_point || paymentPreference.init_point) {
              window.location.href = paymentPreference.sandbox_init_point || paymentPreference.init_point;
              return;
            }
          } catch (paymentError) {
            localStorage.removeItem('zcore_cart');
            mostrarToast('✅ Pedido criado, mas o pagamento online está indisponível no momento.', 'sucesso');
            setTimeout(() => {
              window.location.href = 'pedidos.html';
            }, 1800);
            return;
          }
        }
      }

      // Fallback para modo sem servidor (simulação)
      const total = cart.reduce((sum, item) => sum + (item.preco * item.quantidade), 0);
      const adminOrders = JSON.parse(localStorage.getItem('adminOrders') || '[]');
      const pedidoId = adminOrders.length > 0 ? Math.max(...adminOrders.map(p => p.id || 0)) + 1 : 1;
      const pedido = {
        id: pedidoId,
        data: new Date().toLocaleDateString('pt-BR'),
        itens: cart,
        items: cart.map(item => item.nome).join(', '),
        total: total,
        status: 'Pendente',
        nome: usuarioLogado.nome,
        email: usuarioLogado.email,
        endereco: dadosCheckout.endereco,
        paymentMethod: dadosCheckout.paymentMethod
      };
      adminOrders.push(pedido);
      localStorage.setItem('adminOrders', JSON.stringify(adminOrders));
      let adminProducts = JSON.parse(localStorage.getItem('adminProducts') || '[]');
      cart.forEach(ci => {
        const pIndex = adminProducts.findIndex(x => String(x.id) === String(ci.productId || '') || x.nome === ci.nome);
        if (pIndex !== -1) adminProducts[pIndex].estoque = Math.max(0, (adminProducts[pIndex].estoque || 0) - ci.quantidade);
      });
      localStorage.setItem('adminProducts', JSON.stringify(adminProducts));
      const usuarios = JSON.parse(localStorage.getItem('usuarios') || '[]');
      const usuarioIndex = usuarios.findIndex(u => u.id === usuarioLogado.id);
      if (usuarioIndex !== -1) {
        if (!usuarios[usuarioIndex].pedidos) usuarios[usuarioIndex].pedidos = [];
        usuarios[usuarioIndex].pedidos.push(pedido);
        localStorage.setItem('usuarios', JSON.stringify(usuarios));
        localStorage.setItem('usuarioLogado', JSON.stringify(usuarios[usuarioIndex]));
        salvarPedidoFirestore(pedido, usuarioLogado.id);
      }
      mostrarToast('✅ Pedido confirmado com sucesso! Número: ' + pedidoId);
      setTimeout(() => {
        localStorage.removeItem('zcore_cart');
        window.location.href = 'pedidos.html';
      }, 2000);
    } catch (error) {
      mostrarToast('❌ Erro ao processar pagamento: ' + error.message, 'erro');
    }
  }

  window.onload = function() {
    carregarResumo();
    verificarLogin();
    preencherDadosUsuario();
  };
</script>
<script src="../js/api.js"></script>
<script src="../js/tema.js"></script>
<script src="../js/menu-mobile.js"></script>

</body>
</html>
